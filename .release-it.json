{
  "git": {
    "requireCleanWorkingDir": false,
    "commit": true,
    "commitMessage": "v${version}",
    "tag": true,
    "tagName": "${version}",
    "tagAnnotation": "v${version}",
    "push": true,
    "changelog": "git log --pretty=format:\"* %s (%h)\" ${from}...${to}"
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false
  }
}
